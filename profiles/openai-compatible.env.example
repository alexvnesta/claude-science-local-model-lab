# Generic OpenAI-compatible upstream profile.
#
# Works for vLLM, LM Studio, llama.cpp server, Ollama's OpenAI-compatible
# endpoint, Together, OpenRouter, and similar APIs as long as they implement:
#   POST /v1/chat/completions
#   GET  /v1/models
#
# Copy this file to profiles/local.env, edit values, then run:
#   PROXY_PROFILE=profiles/local.env ./scripts/start-proxy-detached.sh

UPSTREAM_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
UPSTREAM_OPENAI_MODEL=replace-with-your-model-id
UPSTREAM_API_KEY=replace-with-provider-key-or-local-placeholder

PROXY_PROVIDER_NAME=openai-compatible
PROXY_ADVERTISED_MODELS=claude-opus-4-8,replace-with-your-model-id
PROXY_MODEL_DISPLAY_NAMES='{"claude-opus-4-8":"Local Model"}'
PROXY_HOST=127.0.0.1
PROXY_PORT=18080
PROXY_REQUEST_TIMEOUT=240
PROXY_MAX_TOKENS_CAP=4096
PROXY_UPSTREAM_RETRIES=2
PROXY_UPSTREAM_RETRY_DELAY=2
PROXY_STREAM_MODE=direct
PROXY_STREAM_HEARTBEAT_SECONDS=15
PROXY_TOOL_MODE=pass
PROXY_TOOL_VALIDATION=schema
PROXY_TOOL_REPAIR=metadata
PROXY_PARSE_TEXT_TOOL_CALLS=0
PROXY_HARNESS_TOOLS=submit_output
PROXY_HARNESS_TOOL_ALLOWLIST=
PROXY_HARNESS_FORCE_SUBMIT_AFTER_TOOL_RESULTS=0
