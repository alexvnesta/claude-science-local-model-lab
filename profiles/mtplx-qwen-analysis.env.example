# MTPLX/Qwen profile optimized for direct analysis inside Claude Science.
#
# Claude Science may expose 20+ tools even when the user asks for a direct
# answer. Local models can spend a lot of context and latency on those schemas.
# This profile drops tool schemas upstream while preserving the Claude Science
# UI/session loop. Qwen-style textual <tool_call>[...] responses are converted
# back into Anthropic tool_use blocks for narrow review/finalization loops.

MTPLX_OPENAI_BASE_URL=http://127.0.0.1:8030/v1
MTPLX_OPENAI_MODEL=mtplx-qwen36-27b-optimized-quality

PROXY_ADVERTISED_MODELS=claude-opus-4-8,mtplx-qwen36-27b-optimized-quality
PROXY_HOST=127.0.0.1
PROXY_PORT=18080
PROXY_REQUEST_TIMEOUT=180
PROXY_MAX_TOKENS_CAP=1024
PROXY_UPSTREAM_RETRIES=2
PROXY_UPSTREAM_RETRY_DELAY=2
PROXY_STREAM_MODE=buffered
PROXY_TOOL_MODE=drop
PROXY_TOOL_VALIDATION=schema
PROXY_TOOL_REPAIR=metadata
PROXY_PARSE_TEXT_TOOL_CALLS=1
PROXY_SCHEMA_LOG_PATH=_local/tool-schema-capture.jsonl
PROXY_HARNESS_TOOLS=submit_output
