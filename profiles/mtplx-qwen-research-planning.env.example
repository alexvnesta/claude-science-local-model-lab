# MTPLX/Qwen profile for public-data research planning and discovery.
#
# Use this for prompts that ask what data, skills, literature, public resources,
# or compute are available before deciding whether to run code. It exposes a
# focused discovery/planning surface and intentionally hides execution/artifact
# tools such as `python` and `save_artifacts`. Switch to
# mtplx-qwen-execution-probe.env.example only after the plan needs local code or
# artifact creation.

UPSTREAM_OPENAI_BASE_URL=http://127.0.0.1:8030/v1
UPSTREAM_OPENAI_MODEL=mtplx-qwen36-27b-optimized-quality
UPSTREAM_API_KEY=local-mtplx

PROXY_PROVIDER_NAME=mtplx
PROXY_ADVERTISED_MODELS=claude-opus-4-8,${UPSTREAM_OPENAI_MODEL}
PROXY_MODEL_DISPLAY_NAMES='{"claude-opus-4-8":"MTPLX Qwen 27B Research","mtplx-qwen36-27b-optimized-quality":"MTPLX Qwen 27B Research Direct"}'
PROXY_HOST=127.0.0.1
PROXY_PORT=18080
PROXY_REQUEST_TIMEOUT=240
PROXY_MAX_TOKENS_CAP=2048
PROXY_MTPLX_AVOID_BACKGROUND_BYPASS=1
PROXY_MTPLX_BACKGROUND_MAX_TOKENS=48
PROXY_MTPLX_BACKGROUND_NO_HISTORY_MAX_CHARS=4096
PROXY_UPSTREAM_RETRIES=2
PROXY_UPSTREAM_RETRY_DELAY=2
PROXY_STREAM_MODE=buffered
PROXY_STREAM_HEARTBEAT_SECONDS=0
PROXY_TOOL_MODE=pass
PROXY_TOOL_ALLOWLIST=web_search,fetch_article_fulltext,search_skills,skill,list_compute,compute_details,ask_about_compute,summary_query,boundary,generate_plan,update_step_status
PROXY_TOOL_VALIDATION=schema
PROXY_TOOL_REPAIR=metadata
PROXY_FORCE_MENTIONED_TOOL=1
PROXY_PARSE_TEXT_TOOL_CALLS=1
PROXY_SCHEMA_LOG_PATH=_local/tool-schema-capture.jsonl
PROXY_HARNESS_TOOLS=submit_output
PROXY_HARNESS_TOOL_ALLOWLIST=repl,read_file,boundary,summary_query,query_target_history,submit_output
PROXY_HARNESS_FORCE_SUBMIT_AFTER_TOOL_RESULTS=4
PROXY_CLAUDE_SCIENCE_COMPAT=1
