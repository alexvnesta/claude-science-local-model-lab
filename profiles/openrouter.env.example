# OpenRouter upstream profile.
#
# OpenRouter exposes an OpenAI-compatible base URL:
#   https://openrouter.ai/api/v1
#
# Choose a model slug from https://openrouter.ai/models, then run:
#   OPENROUTER_API_KEY=... OPENROUTER_MODEL=provider/model \
#   PROXY_PROFILE=profiles/openrouter.env.example ./scripts/start-proxy-detached.sh

MTPLX_OPENAI_BASE_URL=https://openrouter.ai/api/v1
MTPLX_OPENAI_MODEL=${OPENROUTER_MODEL:-replace-with-openrouter-model-slug}
MTPLX_API_KEY=${OPENROUTER_API_KEY:?Set OPENROUTER_API_KEY before using the OpenRouter profile}

PROXY_ADVERTISED_MODELS=claude-opus-4-8,${MTPLX_OPENAI_MODEL}
PROXY_MODEL_DISPLAY_NAMES="claude-opus-4-8=OpenRouter ${MTPLX_OPENAI_MODEL},${MTPLX_OPENAI_MODEL}=OpenRouter ${MTPLX_OPENAI_MODEL}"
PROXY_HOST=127.0.0.1
PROXY_PORT=18080
PROXY_REQUEST_TIMEOUT=240
PROXY_MAX_TOKENS_CAP=4096
PROXY_UPSTREAM_RETRIES=2
PROXY_UPSTREAM_RETRY_DELAY=2
PROXY_STREAM_MODE=direct
PROXY_TOOL_MODE=pass
PROXY_TOOL_VALIDATION=schema
PROXY_TOOL_REPAIR=metadata
PROXY_PARSE_TEXT_TOOL_CALLS=0
PROXY_HARNESS_TOOLS=submit_output
