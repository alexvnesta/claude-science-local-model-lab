# MTPLX/Qwen profile for focused execution-tool probes.
#
# Use this only after basic gateway and reviewer checks pass, and only for
# prompts that explicitly need Python/artifact execution. It exposes a small
# execution-oriented tool set instead of the full Claude Science catalog; use
# the tool-probe or analysis profile for discovery/planning prompts.
# Direct probes showed Qwen 27B can produce valid `python` and `save_artifacts`
# calls when those tools are isolated and explicitly requested. Reviewer frames
# use a separate allowlist so they can inspect artifacts without exposing those
# inspection tools to the foreground agent. The closeout threshold keeps Qwen
# reviewers from inspecting forever instead of calling `submit_output`.

UPSTREAM_OPENAI_BASE_URL=http://127.0.0.1:8030/v1
UPSTREAM_OPENAI_MODEL=mtplx-qwen36-27b-optimized-quality
UPSTREAM_API_KEY=local-mtplx

PROXY_PROVIDER_NAME=mtplx
PROXY_ADVERTISED_MODELS=claude-opus-4-8,${UPSTREAM_OPENAI_MODEL}
PROXY_MODEL_DISPLAY_NAMES='{"claude-opus-4-8":"MTPLX Qwen 27B Execution","mtplx-qwen36-27b-optimized-quality":"MTPLX Qwen 27B Execution Direct"}'
PROXY_HOST=127.0.0.1
PROXY_PORT=18080
PROXY_REQUEST_TIMEOUT=600
PROXY_MAX_TOKENS_CAP=2048
PROXY_MTPLX_AVOID_BACKGROUND_BYPASS=1
PROXY_MTPLX_BACKGROUND_MAX_TOKENS=48
PROXY_MTPLX_BACKGROUND_NO_HISTORY_MAX_CHARS=4096
PROXY_UPSTREAM_RETRIES=2
PROXY_UPSTREAM_RETRY_DELAY=2
PROXY_STREAM_MODE=buffered
PROXY_STREAM_HEARTBEAT_SECONDS=0
PROXY_TOOL_MODE=pass
PROXY_TOOL_ALLOWLIST=python,save_artifacts
PROXY_TOOL_VALIDATION=schema
PROXY_TOOL_REPAIR=metadata
PROXY_FORCE_MENTIONED_TOOL=1
PROXY_PARSE_TEXT_TOOL_CALLS=1
PROXY_SCHEMA_LOG_PATH=_local/tool-schema-capture.jsonl
PROXY_HARNESS_TOOLS=submit_output
PROXY_HARNESS_TOOL_ALLOWLIST=repl,read_file,boundary,summary_query,query_target_history,submit_output
PROXY_HARNESS_FORCE_SUBMIT_AFTER_TOOL_RESULTS=6
PROXY_CLAUDE_SCIENCE_COMPAT=1
