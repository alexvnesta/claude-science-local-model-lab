# Ollama OpenAI-compatible upstream profile.
#
# Official docs show Ollama serving OpenAI-compatible chat completions at:
#   http://localhost:11434/v1/chat/completions
#
# Start Ollama and pull a model first, for example:
#   ollama pull qwen3:8b
#
# Then run:
#   OLLAMA_MODEL=qwen3:8b PROXY_PROFILE=profiles/ollama.env.example ./scripts/start-proxy-detached.sh

UPSTREAM_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
UPSTREAM_OPENAI_MODEL=${OLLAMA_MODEL:-qwen3:8b}
UPSTREAM_API_KEY=${OLLAMA_API_KEY:-ollama}

PROXY_PROVIDER_NAME=ollama
PROXY_ADVERTISED_MODELS=claude-opus-4-8,${UPSTREAM_OPENAI_MODEL}
PROXY_MODEL_DISPLAY_NAMES="claude-opus-4-8=Ollama Local Model,${UPSTREAM_OPENAI_MODEL}=Ollama ${UPSTREAM_OPENAI_MODEL}"
PROXY_HOST=127.0.0.1
PROXY_PORT=18080
PROXY_REQUEST_TIMEOUT=240
PROXY_MAX_TOKENS_CAP=4096
PROXY_UPSTREAM_RETRIES=2
PROXY_UPSTREAM_RETRY_DELAY=2
PROXY_STREAM_MODE=direct
PROXY_STREAM_HEARTBEAT_SECONDS=15
PROXY_TOOL_MODE=pass
PROXY_TOOL_VALIDATION=schema
PROXY_HARNESS_TOOLS=submit_output
PROXY_CLAUDE_SCIENCE_COMPAT=0
